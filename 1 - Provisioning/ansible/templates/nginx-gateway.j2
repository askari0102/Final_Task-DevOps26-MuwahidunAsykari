# ─── Default Catch-All (Security) ─────────────────────────────────────────────
server {
    listen 80 default_server;
    server_name _;
    return 444; # Connection closed without response
}

server {
    listen 443 ssl default_server;
    server_name _;
    ssl_certificate /etc/letsencrypt/live/{{ domain_name }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ domain_name }}/privkey.pem;
    return 444;
}

# ─── Monitoring ───────────────────────────────────────────────────────────────
# Node Exporter
server {
    listen 80;
    server_name exporter.{{ domain_name }};
    return 301 https://$host$request_uri;
}
server {
    listen 443 ssl;
    server_name exporter.{{ domain_name }};

    ssl_certificate /etc/letsencrypt/live/{{ domain_name }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ domain_name }}/privkey.pem;

    location / {
        proxy_pass http://{{ hostvars['monitoring_server']['ansible_host'] }}:{{ node_exporter_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}

# Prometheus
server {
    listen 80;
    server_name prom.{{ domain_name }};
    return 301 https://$host$request_uri;
}
server {
    listen 443 ssl;
    server_name prom.{{ domain_name }};

    ssl_certificate /etc/letsencrypt/live/{{ domain_name }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ domain_name }}/privkey.pem;

    auth_basic "Prometheus";
    auth_basic_user_file /etc/nginx/.htpasswd;

    location / {
        proxy_pass http://{{ hostvars['monitoring_server']['ansible_host'] }}:{{ prometheus_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}

